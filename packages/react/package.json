{
  "name": "@pds/react",
  "version": "0.1.0",
  "description": "PDS React components for agent-facing product surfaces.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrocarlop/pds.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/pedrocarlop/pds#readme",
  "bugs": {
    "url": "https://github.com/pedrocarlop/pds/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./starter": {
      "types": "./dist/starter.d.ts",
      "import": "./dist/starter.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json && node ../../scripts/copy-package-css.mjs",
    "clean": "node ../../scripts/clean-package.mjs",
    "lint": "eslint src --max-warnings=0",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@pds/tokens": "workspace:^",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "8.5.2",
    "input-otp": "^1.4.2",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.7.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "vaul": "1.1.2"
  }
}
