{
  "name": "@pds/tokens",
  "version": "0.0.0",
  "description": "PDS design tokens and CSS custom properties.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./colour.css": "./dist/colour.css",
    "./typography.css": "./dist/typography.css",
    "./spacing.css": "./dist/spacing.css",
    "./elevation.css": "./dist/elevation.css",
    "./motion.css": "./dist/motion.css"
  },
  "files": ["dist"],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json && node -e \"const fs=require('node:fs');fs.mkdirSync('dist',{recursive:true});for(const file of fs.readdirSync('src').filter((name)=>name.endsWith('.css'))){fs.copyFileSync('src/'+file,'dist/'+file)}\"",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
