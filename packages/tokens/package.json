{
  "name": "@pds/tokens",
  "version": "0.0.0",
  "description": "PDS design tokens and CSS custom properties.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./colour.css": "./dist/colour.css",
    "./typography.css": "./dist/typography.css",
    "./spacing.css": "./dist/spacing.css",
    "./layout.css": "./dist/layout.css",
    "./elevation.css": "./dist/elevation.css",
    "./motion.css": "./dist/motion.css"
  },
  "files": ["dist"],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json && node ../../scripts/copy-package-css.mjs",
    "clean": "node ../../scripts/clean-package.mjs",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
