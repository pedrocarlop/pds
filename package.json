{
  "name": "@pds/workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for the PDS design system.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "check": "pnpm lint && pnpm docs:lint && pnpm css:lint && pnpm typecheck && pnpm test && pnpm examples:build && pnpm examples:visual:build && pnpm design:lint",
    "clean:workspace": "node scripts/clean-workspace.mjs",
    "css:lint": "node scripts/lint-component-css-tokens.mjs",
    "design:lint": "design.md lint DESIGN.md",
    "docs:lint": "node scripts/lint-agent-docs.mjs && pnpm plugin:context:check",
    "examples:build": "turbo run build --filter=@pds/examples-react",
    "examples:dev": "pnpm build && pnpm --filter @pds/examples-react dev",
    "examples:visual": "pnpm build && pnpm --filter @pds/examples-react ladle:serve",
    "examples:visual:build": "pnpm build && pnpm --filter @pds/examples-react ladle:build",
    "lint": "eslint scripts --max-warnings=0 && turbo run lint --filter=./packages/* --filter=./examples/*",
    "plugin:context": "node scripts/sync-plugin-context.mjs",
    "plugin:context:check": "node scripts/sync-plugin-context.mjs --check",
    "test": "pnpm --filter @pds/react test && pnpm --filter @pds/cli test",
    "typecheck": "turbo run typecheck --filter=./packages/*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/design.md": "^0.1.1",
    "eslint": "^10.3.0",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
