{
  "name": "pds",
  "version": "0.0.0",
  "description": "A React UI library skeleton designed from the ground up for LLM agents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/pds.cjs",
  "module": "./dist/pds.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pds.js",
      "require": "./dist/pds.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "check": "pnpm typecheck && pnpm lint && pnpm build",
    "lint": "eslint src vite.config.ts --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/pedrocarlop/pds.git"
  },
  "bugs": {
    "url": "https://github.com/pedrocarlop/pds/issues"
  },
  "homepage": "https://github.com/pedrocarlop/pds#readme",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.6",
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  }
}
