{
  "name": "@pds/workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for the PDS design system.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm design:lint",
    "design:lint": "design.md lint DESIGN.md",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/design.md": "^0.1.1",
    "eslint": "^10.3.0",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
